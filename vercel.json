{
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/s", "destination": "/api/share" },
    { "source": "/", "has": [{ "type": "host", "value": "pf.sokonara.co.jp" }], "destination": "/pf/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
